# Supabase Client configuration untuk Foto Momen
# ⚠️ Next.js: gunakan prefix NEXT_PUBLIC_ (bukan VITE_)
NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_URL_HERE"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"

# URL base aplikasi (untuk metadata OG share link)
NEXT_PUBLIC_BASE_URL="https://foto-momen.vercel.app"

# Admin Dashboard Password
NEXT_PUBLIC_ADMIN_PASSWORD="admin_password_rahasia"
